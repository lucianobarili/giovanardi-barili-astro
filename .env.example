# Formulario de contacto (Formspree). Crear un form en https://formspree.io
# y pegar el ID acá (la parte final de la URL, ej: https://formspree.io/f/abcdwxyz -> abcdwxyz).
PUBLIC_FORMSPREE_FORM_ID=

# Dejar vacío/ausente hasta el cutover de Fase 3 (dominio propio en vivo).
# En "true", el sitio se sirve indexable (robots.txt + meta robots). Sin
# setear, todo el sitio se sirve con noindex — es el default seguro para
# no competir con estudiogiovanardibarili.com mientras siga vivo.
PUBLIC_ALLOW_INDEXING=
