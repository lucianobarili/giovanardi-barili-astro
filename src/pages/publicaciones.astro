---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Heading from "../components/ui/Heading.astro";
import Button from "../components/ui/Button.astro";
import { site } from "../data/site";
---

<BaseLayout
  title="Publicaciones"
  description="Próximamente: artículos y novedades sobre derecho empresarial, contratos, sucesiones y urbanismo."
>
  <section class="py-24 sm:py-32">
    <Container class="mx-auto max-w-xl text-center">
      <Heading as="h1" eyebrow="Publicaciones" align="center" class="mx-auto">
        Próximamente
      </Heading>
      <p class="mt-6 text-lg text-ink-soft">
        Estamos preparando artículos sobre derecho empresarial, contratos,
        sucesiones y urbanismo. Mientras tanto, escribinos directamente y te
        ayudamos con tu consulta.
      </p>
      <div class="mt-8 flex justify-center">
        <Button href={site.whatsapp.url} target="_blank" size="lg">WhatsApp ahora →</Button>
      </div>
    </Container>
  </section>
</BaseLayout>
