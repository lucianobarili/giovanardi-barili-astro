---
import { Image } from "astro:assets";

interface Props {
  name: string;
  photoSrc?: ImageMetadata;
  tone?: "primary" | "accent";
  size?: "md" | "lg";
  class?: string;
}

const { name, photoSrc, tone = "primary", size = "lg", class: className } = Astro.props;

const initials = name
  .split(" ")
  .map((word) => word[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

const toneClasses: Record<string, string> = {
  primary: "bg-primary text-surface",
  accent: "bg-accent text-surface",
};

const sizeClasses: Record<string, string> = {
  md: "h-16 w-16 text-lg",
  lg: "h-28 w-28 text-3xl sm:h-32 sm:w-32",
};
---

{
  photoSrc ? (
    <Image
      src={photoSrc}
      alt={name}
      width={256}
      height={256}
      class:list={["rounded-full object-cover", sizeClasses[size], className]}
    />
  ) : (
    <div
      aria-hidden="true"
      class:list={[
        "flex items-center justify-center rounded-full font-serif font-medium",
        toneClasses[tone],
        sizeClasses[size],
        className,
      ]}
    >
      {initials}
    </div>
  )
}
