---
interface Props {
  as?: "div" | "section" | "header" | "footer" | "nav";
  class?: string;
  [key: string]: unknown;
}

const { as: Tag = "div", class: className, ...rest } = Astro.props;
---

<Tag class:list={["mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8", className]} {...rest}>
  <slot />
</Tag>
