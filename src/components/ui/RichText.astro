---
// Renderiza texto plano con soporte mínimo para **negrita** — evita mezclar
// HTML dentro de los archivos de datos.
interface Props {
  text: string;
  class?: string;
}

const { text, class: className } = Astro.props;

const parts = text
  .split(/(\*\*[^*]+\*\*)/g)
  .filter(Boolean)
  .map((part) => {
    const isBold = part.startsWith("**") && part.endsWith("**");
    return { text: isBold ? part.slice(2, -2) : part, bold: isBold };
  });
---

<span class={className}>
  {parts.map((part) => (part.bold ? <strong>{part.text}</strong> : part.text))}
</span>
