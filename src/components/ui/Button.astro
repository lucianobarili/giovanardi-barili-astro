---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  type?: "button" | "submit";
  target?: "_blank";
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  target,
  class: className,
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-colors duration-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:opacity-50 disabled:pointer-events-none";

const variants: Record<string, string> = {
  primary: "bg-accent text-white hover:bg-primary-light",
  secondary: "border border-primary text-primary hover:bg-primary hover:text-white",
  ghost: "text-primary hover:bg-surface-alt",
};

const sizes: Record<string, string> = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-6 py-3.5 text-base",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={href ? undefined : type}
  target={target}
  rel={target === "_blank" ? "noopener noreferrer" : undefined}
  class:list={[base, variants[variant], sizes[size], className]}
  {...rest}
>
  <slot />
</Tag>
