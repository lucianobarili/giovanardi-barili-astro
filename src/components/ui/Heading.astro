---
interface Props {
  as?: "h1" | "h2" | "h3" | "h4";
  eyebrow?: string;
  align?: "left" | "center";
  class?: string;
}

const { as: Tag = "h2", eyebrow, align = "left", class: className } = Astro.props;

const sizes: Record<string, string> = {
  h1: "text-4xl sm:text-5xl lg:text-6xl leading-[1.1]",
  h2: "text-3xl sm:text-4xl lg:text-5xl leading-tight",
  h3: "text-2xl sm:text-3xl leading-snug",
  h4: "text-xl sm:text-2xl leading-snug",
};
---

<div class:list={[align === "center" ? "text-center" : "text-left", className]}>
  {
    eyebrow && (
      <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-accent">
        {eyebrow}
      </p>
    )
  }
  <Tag class:list={[sizes[Tag], "font-serif font-medium text-primary text-balance"]}>
    <slot />
  </Tag>
</div>
