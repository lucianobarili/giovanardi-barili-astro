---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Button from "../ui/Button.astro";
import { getWhatsAppUrl } from "../../data/site";

const trustPoints = [
  "13+ años de experiencia",
  "Respuesta en el día",
  "Asesoría online en toda la PBA",
];
---

<section class="py-24 sm:py-32">
  <Container class="mx-auto max-w-[65ch] text-center">
    <Heading as="h1" eyebrow="Estudio Jurídico · Mar del Plata" align="center" class="mx-auto">
      Asesoramiento legal ágil, confiable y sin vueltas
    </Heading>

    <p class="mx-auto mt-6 max-w-[55ch] text-lg text-ink-soft">
      Un estudio que combina derecho privado y arquitectura. Resolvemos tus
      asuntos societarios, contractuales y patrimoniales en toda la
      Provincia de Buenos Aires, con respuesta inmediata y asesoría 100%
      online.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <Button href={getWhatsAppUrl()} target="_blank" size="lg">
        WhatsApp ahora →
      </Button>
      <Button href="#areas" variant="secondary" size="lg">Ver áreas</Button>
    </div>

    <ul class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-ink-soft">
      {
        trustPoints.map((point) => (
          <li class="flex items-center gap-2">
            <span class="h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true" />
            {point}
          </li>
        ))
      }
    </ul>
  </Container>
</section>
