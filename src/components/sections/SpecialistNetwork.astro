---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Briefcase from "@lucide/astro/icons/briefcase";
import PiggyBank from "@lucide/astro/icons/piggy-bank";
import { specialistNetwork } from "../../data/specialistNetwork";

const icons = {
  briefcase: Briefcase,
  "piggy-bank": PiggyBank,
};
---

<section class="bg-surface py-16 sm:py-20">
  <Container>
    <Heading as="h2" eyebrow="Trabajamos en red" align="center" class="mx-auto max-w-2xl">
      Especialistas de confianza para vos
    </Heading>
    <p class="mx-auto mt-4 max-w-xl text-center text-ink-soft">
      Además de lo que atendemos directamente, te conectamos con
      profesionales especializados para cubrir cada necesidad.
    </p>

    <div class="mx-auto mt-10 grid max-w-2xl gap-4 sm:grid-cols-2">
      {
        specialistNetwork.map((area) => {
          const Icon = icons[area.icon];
          return (
            <div class="flex items-start gap-4 rounded-xl border border-border bg-surface-alt p-6">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white text-accent">
                <Icon class="h-5 w-5" aria-hidden="true" />
              </div>
              <div>
                <h3 class="font-serif text-lg text-primary">{area.title}</h3>
                <p class="mt-1 text-sm text-ink-soft">{area.description}</p>
                <p class="mt-2 text-xs font-medium uppercase tracking-wide text-ink-soft">
                  {area.note}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>
  </Container>
</section>
