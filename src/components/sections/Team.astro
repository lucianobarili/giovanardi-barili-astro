---
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Card from "../ui/Card.astro";
import Avatar from "../ui/Avatar.astro";
import { team } from "../../data/team";
---

<section id="equipo" class="scroll-mt-24 bg-surface py-16 sm:py-24">
  <Container>
    <Heading as="h2" eyebrow="Quiénes somos" align="center" class="mx-auto max-w-2xl">
      El equipo
    </Heading>

    <div class="mx-auto mt-12 grid max-w-3xl gap-6 sm:grid-cols-2">
      {
        team.map((member) => (
          <Card class="text-center">
            <Avatar name={member.name} tone={member.tone} class="mx-auto" />
            <h3 class="mt-4 font-serif text-xl text-primary">{member.name}</h3>
            <p class="mt-1 text-sm font-semibold uppercase tracking-wide text-accent">
              {member.role}
            </p>
            <p class="mt-3 text-sm text-ink-soft">{member.bio}</p>
            {member.extra && <p class="mt-3 text-xs text-ink-soft">{member.extra}</p>}
          </Card>
        ))
      }
    </div>

    <div class="mt-8 text-center">
      <a
        href="/nosotros"
        class="inline-flex items-center gap-1 text-sm font-semibold text-accent transition-colors hover:text-primary"
      >
        Conocé más sobre el equipo →
      </a>
    </div>
  </Container>
</section>
