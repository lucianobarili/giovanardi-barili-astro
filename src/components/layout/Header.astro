---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import Wordmark from "../ui/Wordmark.astro";
import Nav from "./Nav.astro";
import MobileMenu from "./MobileMenu.astro";
import { getWhatsAppUrl } from "../../data/site";
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur">
  <Container
    as="nav"
    aria-label="Navegación principal"
    class="relative flex h-20 items-center justify-between"
  >
    <a href="/">
      <Wordmark />
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <Nav orientation="horizontal" />
      <Button href={getWhatsAppUrl()} target="_blank">WhatsApp ahora →</Button>
    </div>

    <MobileMenu />
  </Container>
</header>
