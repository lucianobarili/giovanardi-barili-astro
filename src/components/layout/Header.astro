---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import Logo from "../ui/Logo.astro";
import Nav from "./Nav.astro";
import MobileMenu from "./MobileMenu.astro";
import { site } from "../../data/site";
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur">
  <Container
    as="nav"
    aria-label="Navegación principal"
    class="relative flex h-20 items-center justify-between"
  >
    <a href="/" class="flex items-center gap-3">
      <Logo />
      <span class="font-serif text-lg font-medium text-primary">{site.name}</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      <Nav orientation="horizontal" />
      <Button href={site.whatsapp.url} target="_blank">WhatsApp ahora →</Button>
    </div>

    <MobileMenu />
  </Container>
</header>
